# project-conventions.rules
# Generated by $init-project for memory-bank. Starlark-compatible literals only.
project_name = "memory-bank"
frontend_dir = "ui"
pkg_manager = "npm"
has_typecheck = True
backend_type = "node-mcp-cli-sqlite"
build_command = "npm run build"
bundle_command = "npm run bundle"
typecheck_command = "npx tsc --noEmit"
lint_command = ""
test_command = "npm test"
unit_test_command = "npm test"
integration_test_command = "npx vitest run test/integration.test.ts test/sync.test.ts test/fact-integration.test.ts test/mcp-facts.test.ts test/sync-export-import.test.ts"
ui_dev_command = "node ui/server.cjs"
qa_inventory_path = ".qa-inventory.json"
qa_test_plan_path = "docs/qa-test-plan.md"
qa_evidence_path = ".qa-evidence.json"
qa_cycle_marker = ".qa-cycle-passed"
hard_contract_path = ".codex/loopy-era/hard-process-contract.json"
hard_contract_validator = "python3 .codex/scripts/validate-hard-process-contract.py --project-root . --require-project-contract --json"
qa_cycle_feature_command = "python3 ~/.codex/scripts/qa-cycle-runtime.py --project-root . --scope feature --max-rounds 1"
qa_cycle_full_regression_command = "python3 ~/.codex/scripts/qa-cycle-runtime.py --project-root . --scope full-regression --max-rounds 1"
source_dirs = ["src", "scripts", "cli", "ui", "hooks", "test"]
compiled_dir = "dist"
test_glob = "test/**/*.test.ts"
never_do = [
  "use require() in src TypeScript modules",
  "omit .js extension on local ESM imports",
  "leave initDatabase handles unclosed",
  "interpolate user input into SQL",
  "use INSERT OR REPLACE against sqlite-vec virtual tables",
  "claim UI QA from smoke-only evidence",
  "bypass hooks with --no-verify",
]
