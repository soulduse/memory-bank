{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/ai-commit-msg-ban.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/codex-review-gate.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/no-env-commit.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/no-verify-ban.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/qa-gate-before-push.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/dependency-audit.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/html-api-gate.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/portless-required.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/validate-before-commit.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/claim-done-gate.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/mid-loop-question-detector.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/premature-completion-detector.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/mid-loop-question-reminder.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/premature-completion-reminder.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/no-localstorage-universal.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/pipefail-grep-warn.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/scaffold-violation-check.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/shell-bare-cli-check.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/auto-validate.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/code-quality-check.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/formatter-check.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/react-grab-inject.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/require-isPWA-check.sh"
          },
          {
            "type": "command",
            "command": "./.codex/hooks/sql-injection-check.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/subagent-verify.sh"
          }
        ]
      }
    ]
  }
}