#!/usr/bin/env node
// memory-bank-cloud-sync — local sidecar spool sync CLI (Phase 4)
// Subcommands: status | push | retry | doctor
//   status  : show pending spool events + cloud config mode (no network)
//   doctor  : diagnose config/session readiness without pushing
//   push    : login (or reuse session) and flush pending spool events to the cloud plane
//   retry   : alias of push (acked events are skipped, so it only reprocesses pending/failed)
// Idempotent: acked events are never reprocessed; failed events stay pending for retry.
// Never logs tokens or privileged values.
import os from 'os';
import path from 'path';
import { fileURLToPath } from 'url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const distDir = path.join(__dirname, '..', 'dist');

function spoolDir() {
  return (
    process.env.MEMORY_BANK_CLOUD_SPOOL_DIR ||
    path.join(os.homedir(), '.config', 'superpowers', 'memory-bank-cloud-spool')
  );
}

function out(obj) {
  process.stdout.write(`${JSON.stringify(obj, null, 2)}\n`);
}
function err(msg) {
  process.stderr.write(`${msg}\n`);
}

function countKinds(events) {
  return events.reduce((acc, e) => {
    acc[e.kind] = (acc[e.kind] || 0) + 1;
    return acc;
  }, {});
}

async function load() {
  const [spoolMod, serverMod, syncMod, configMod, coreMod] = await Promise.all([
    import(path.join(distDir, 'memory-bank-cloud-spool.js')),
    import(path.join(distDir, 'memory-bank-cloud-server.js')),
    import(path.join(distDir, 'memory-bank-cloud-sync.js')),
    import(path.join(distDir, 'memory-bank-cloud-config.js')),
    import(path.join(distDir, 'memory-bank-cloud.js')),
  ]);
  return { spoolMod, serverMod, syncMod, configMod, coreMod };
}

async function resolveSessionToken(host, coreMod) {
  const sessionToken = process.env.MEMORY_BANK_CLOUD_SESSION_TOKEN;
  if (sessionToken) return sessionToken;
  const loginToken = process.env.MEMORY_BANK_CLOUD_TOKEN;
  if (!loginToken) return null;
  const isAsync = host instanceof coreMod.AsyncMemoryBankCloudHost;
  const session = isAsync ? await host.loginWithToken(loginToken) : host.loginWithToken(loginToken);
  return session.sessionToken;
}

async function main() {
  const cmd = process.argv[2] || 'status';
  let mods;
  try {
    mods = await load();
  } catch (e) {
    err('Failed to load built modules. Run `npm run build` first.');
    err(e instanceof Error ? e.message : String(e));
    process.exit(1);
    return;
  }
  const { spoolMod, serverMod, syncMod, configMod, coreMod } = mods;
  const config = configMod.loadMemoryBankCloudConfig();
  const dir = spoolDir();
  const spool = new spoolMod.MemoryBankCloudSpool(dir);

  if (cmd === 'status') {
    const { events, malformed } = spool.scan();
    out({ command: 'status', mode: config.mode, spoolDir: dir, spoolFile: spool.filePath, pending: events.length, corrupt: malformed.length, kinds: countKinds(events) });
    return;
  }

  if (cmd === 'doctor') {
    const { events, malformed } = spool.scan();
    const issues = [];
    if (config.mode !== 'supabase') issues.push('config.mode != supabase — set MEMORY_BANK_CLOUD_SUPABASE_URL + token to push to the cloud plane');
    if (!config.supabaseUrl) issues.push('missing SUPABASE_URL / MEMORY_BANK_CLOUD_SUPABASE_URL');
    if (!config.supabasePrivilegedToken) issues.push('missing privileged token (SUPABASE_SERVICE_ROLE_TOKEN / MEMORY_BANK_CLOUD_SUPABASE_TOKEN)');
    if (!process.env.MEMORY_BANK_CLOUD_SESSION_TOKEN && !process.env.MEMORY_BANK_CLOUD_TOKEN) {
      issues.push('no session — set MEMORY_BANK_CLOUD_SESSION_TOKEN or MEMORY_BANK_CLOUD_TOKEN before push');
    }
    if (malformed.length > 0) {
      issues.push(`${malformed.length} malformed spool line(s) — run \`memory-bank-cloud-sync quarantine\` to isolate them`);
    }
    out({ command: 'doctor', mode: config.mode, spoolDir: dir, pending: events.length, corrupt: malformed.length, ok: issues.length === 0, issues });
    if (issues.length > 0) process.exit(1);
    return;
  }

  if (cmd === 'quarantine') {
    const result = spool.quarantineMalformed();
    out({ command: 'quarantine', quarantined: result.quarantined, corruptPath: result.corruptPath });
    return;
  }

  if (cmd === 'push' || cmd === 'retry') {
    const host = serverMod.createMemoryBankCloudHostFromEnv();
    const sessionToken = await resolveSessionToken(host, coreMod);
    if (!sessionToken) {
      err('push requires a session: set MEMORY_BANK_CLOUD_SESSION_TOKEN or MEMORY_BANK_CLOUD_TOKEN');
      process.exit(2);
      return;
    }
    const isAsync = host instanceof coreMod.AsyncMemoryBankCloudHost;
    const result = isAsync
      ? await syncMod.syncMemoryBankCloudSpoolAsync(host, sessionToken, spool)
      : syncMod.syncMemoryBankCloudSpool(host, sessionToken, spool);
    out({
      command: cmd,
      processed: result.processed,
      failed: result.failed.length,
      failures: result.failed.map((f) => ({ id: f.event.id, kind: f.event.kind, error: f.error })),
    });
    if (result.failed.length > 0) process.exit(1);
    return;
  }

  err(`Unknown command: ${cmd}\nUsage: memory-bank-cloud-sync [status|push|retry|doctor|quarantine]`);
  process.exit(2);
}

main().catch((e) => {
  err(e instanceof Error ? e.stack ?? e.message : String(e));
  process.exit(1);
});
